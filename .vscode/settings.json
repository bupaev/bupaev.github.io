{
    "stylelint.enable": true,
    "stylelint.validate": [
        "css",
        "scss"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.stylelint": "explicit"
    },
    "css.validate": false,
    "scss.validate": false,
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
        "typescript": "typescriptreact"
    }
}