  },
  "dependencies": {
    "next": "16.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.1",
    "smoothscroll-polyfill": "^0.4.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/smoothscroll-polyfill": "^0.3.4",
    "bulma": "^1.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.0.2",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5"
