---
import "../styles/main.scss";
import "../styles/tailwind.css";
import ogImage from "../assets/images/paul-buramensky-og.avif";

import nunitoLatin400 from "../assets/fonts/Nunito-400-latin11.woff2?url";
import nunitoLatin700 from "../assets/fonts/Nunito-700-latin16.woff2?url";
import dosisLatin400 from "../assets/fonts/Dosis-400-latin3.woff2?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hi! I'm Paul Buramensky",
  description = "I'm Lead Front-End Engineer with 15+ years of experience. UX-driven, AI-fluent, framework-agnostic.",
} = Astro.props;

const ogImageUrl = new URL(ogImage.src, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preload" href={nunitoLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={nunitoLatin700} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={dosisLatin400} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="My web CV" />
    <meta property="og:url" content="https://paulbu.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImage.width)} />
    <meta property="og:image:height" content={String(ogImage.height)} />
    <meta property="og:locale" content="en" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "name": "Paul Buramensky",
        "jobTitle": "Lead Front-End Engineer",
        "url": "https://paulbu.com",
        "email": "mail@paulbu.com",
        "telephone": "+49 1556 5551632",
        "image": ogImageUrl,
        "description": "Lead Front-End Engineer with 15+ years of experience. UX-driven, AI-fluent, framework-agnostic.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Berlin",
          "addressCountry": "DE"
        },
        "sameAs": [
          "https://www.linkedin.com/in/paul-buramensky"
        ],
        "knowsAbout": [
          "JavaScript", "TypeScript", "React", "Vue.js", "Next.js", "Astro",
          "Nuxt.js", "HTML5", "CSS3", "SCSS", "Node.js", "Express", "GraphQL",
          "REST API Design", "Docker", "AWS", "UX Design", "Accessibility",
          "Design Systems", "AI Pair Programming", "Prompt Engineering"
        ],
        "knowsLanguage": [
          { "@type": "Language", "name": "English", "alternateName": "en" },
          { "@type": "Language", "name": "Russian", "alternateName": "ru" },
          { "@type": "Language", "name": "German", "alternateName": "de" }
        ],
        "alumniOf": [
          {
            "@type": "EducationalOrganization",
            "name": "Omsk State Technical University"
          }
        ],
        "hasOccupation": {
          "@type": "Occupation",
          "name": "Lead Front-End Engineer",
          "occupationalCategory": "15-1254",
          "skills": "JavaScript, TypeScript, React, Vue.js, UX Design, Accessibility, Team Leadership"
        }
      }
    })} />

    <!-- Google Analytics (via Partytown web worker) -->
    <script type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-HHHHHSLPX3"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HHHHHSLPX3');
    </script>

    <script is:inline>
      // Restore theme from cookie to prevent flashing
      // This script is inlined in the head to execute synchronously before any paint
      (function() {
        const getCookie = (name) => {
          const matches = document.cookie.match(
            new RegExp(
              "(?:^|; )" + name.replace(/([.$?*|{}()[\]\\/+^])/g, "\\$1") + "=([^;]*)",
            ),
          );
          return matches ? matches[1] : undefined;
        };

        const theme = getCookie("color-scheme");
        if (theme) {
          document.documentElement.setAttribute("data-color-scheme", theme);
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.setAttribute("data-color-scheme", "dark");
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import("../scripts/console-greeting");
</script>
