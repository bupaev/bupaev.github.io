---
import { getImage } from "astro:assets";
import { CvHeroArea as CvHeroAreaReact } from "./cv-hero-area";
import portraitDesktop from "./images/portrait-desktop.avif";
import portraitMobile from "./images/portrait-mobile-2x.avif";

const desktopPlaceholder = await getImage({
  src: portraitDesktop,
  width: 20,
  format: "avif",
});
const mobilePlaceholder = await getImage({
  src: portraitMobile,
  width: 20,
  format: "avif",
});
---

<CvHeroAreaReact
  client:load
  desktopImage={{
    src: portraitDesktop.src,
    placeholderSrc: desktopPlaceholder.src,
  }}
  mobileImage={{
    src: portraitMobile.src,
    placeholderSrc: mobilePlaceholder.src,
  }}
/>
