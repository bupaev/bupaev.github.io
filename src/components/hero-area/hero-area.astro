---
import { getImage } from "astro:assets";
import { HeroArea } from "./hero-area";
import portraitDesktop from "./images/portrait-desktop.avif";
import portraitMobile from "./images/portrait-mobile-2x.avif";
import portraitDarkDesktop from "./images/portrait-dark-desktop.avif";
import portraitDarkMobile from "./images/portrait-dark-mobile-2x.avif";

const desktopPlaceholder = await getImage({
  src: portraitDesktop,
  width: 20,
  format: "avif",
});
const mobilePlaceholder = await getImage({
  src: portraitMobile,
  width: 20,
  format: "avif",
});

const darkDesktopPlaceholder = await getImage({
  src: portraitDarkDesktop,
  width: 20,
  format: "avif",
});

const darkMobilePlaceholder = await getImage({
  src: portraitDarkMobile,
  width: 20,
  format: "avif",
});
---

<HeroArea
  client:load
  desktopImage={{
    src: portraitDesktop.src,
    placeholderSrc: desktopPlaceholder.src,
  }}
  mobileImage={{
    src: portraitMobile.src,
    placeholderSrc: mobilePlaceholder.src,
  }}
  darkDesktopImage={{
    src: portraitDarkDesktop.src,
    placeholderSrc: darkDesktopPlaceholder.src,
  }}
  darkMobileImage={{
    src: portraitDarkMobile.src,
    placeholderSrc: darkMobilePlaceholder.src,
  }}
/>
